font-thicken = false
# adjust-cell-width = 6%
# adjust-cell-height = -8%
# adjust-cell-height = 2%
# adjust-cursor-height = -10%

window-padding-x = 0,0
window-padding-y = 0,0
window-padding-balance = true

cursor-color=#E9B3FB
# cursor-style = bar
cursor-opacity = 0.8
cursor-style-blink = true


background-blur-radius = 30
# background-opacity = 0.96
# background-blur=macos-glass-regular

link-url = true
copy-on-select = clipboard

macos-option-as-alt = true
macos-titlebar-style = hidden
macos-window-shadow = true

auto-update = check
auto-update-channel = tip

bold-is-bright = true
# minimum-contrast = 1.05
mouse-hide-while-typing = true

keybind = super+i=inspector:toggle
keybind = super+r=reload_config
keybind = ctrl+.=csi:46;5u

# custom-shader = ./shaders/cursor_smear_fade.glsl
# custom-shader = ./shaders/cursor_sweep.glsl
custom-shader = ./shaders/cursor_synesthaxia.glsl
# custom-shader = ./shaders/cursor_follow_eye.glsl
# custom-shader = ./shaders/cursor_warp.glsl
# custom-shader = ./shaders/ripple_cursor.glsl
custom-shader = ./shaders/sonic_boom_cursor.glsl

keybind = shift+enter=text:\n
