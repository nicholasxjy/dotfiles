#!/usr/bin/env sh

# necessary to load scripting-addition during startup on macOS Big Sur
# *yabai --load-sa* is configured to run through sudo without a password
if ! sudo yabai --load-sa 2>/dev/null; then
    echo "yabai scripting addition not loaded: partially disable SIP filesystem/debug protections"
fi
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa >/dev/null 2>&1"

sleep 1

SPACES=(
  terminal
  browser
  tools
  chat
  other
)

CURRENT=$(yabai -m query --spaces | jq 'length')
TARGET=${#SPACES[@]}

# 创建缺失的spaces
while [ "$CURRENT" -lt "$TARGET" ]; do
    yabai -m space --create
    CURRENT=$((CURRENT + 1))
done

# label
for i in "${!SPACES[@]}"; do
    yabai -m space $((i+1)) --label "${SPACES[$i]}"
done

# signals
yabai -m signal --add event=window_destroyed active=yes action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse &> /dev/null || yabai -m window --focus \$(yabai -m query --windows --space | jq .[0].id) &> /dev/null"
yabai -m signal --add event=window_minimized active=yes action="if \$(yabai -m query --windows --window \$YABAI_WINDOW_ID | jq -r '.\"is-floating\"'); then yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse &> /dev/null || yabai -m window --focus \$(yabai -m query --windows --space | jq .[0].id) &> /dev/null; fi"


# global settings
yabai -m config                              \
    external_bar                off:41:0     \
    mouse_follows_focus         off          \
    focus_follows_mouse         autoraise    \
    window_placement            second_child \
    window_shadow               on           \
    insert_feedback_color       0xaad75f5f   \
    split_ratio                 0.50         \
    split_type                  auto         \
    auto_balance                on           \
    top_padding                 20           \
    left_padding                20           \
    right_padding               20           \
    bottom_padding              20           \
    window_gap                  20           \
    layout                      float        \
    mouse_modifier              fn           \
    mouse_action1               move         \
    mouse_action2               resize       \
    mouse_drop_action           swap

# per-space layout
for space in "${SPACES[@]}"; do
    case "$space" in
        tools|chat)
            yabai -m config --space "$space" layout bsp
            ;;
        *)
            yabai -m config --space "$space" layout float
            ;;
    esac
done

# window effects require yabai's scripting addition and partial SIP disable
if yabai -m config window_animation_duration 0.25 2>/dev/null; then
    yabai -m config window_animation_easing ease_out_cubic
    yabai -m config skip_window_focus_animation off
    yabai -m config window_opacity on
    yabai -m config window_opacity_duration 0.25
    yabai -m config active_window_opacity 0.90
    yabai -m config normal_window_opacity 0.50
else
    echo "window opacity/animation unavailable: partially disable SIP filesystem/debug protections for yabai"
fi

if ! yabai -m config window_topmost off 2>/dev/null; then
    echo "skipping unsupported yabai setting: window_topmost"
fi

if yabai -m config window_border on 2>/dev/null; then
    yabai -m config active_window_border_color 0xBF775759
    yabai -m config normal_window_border_color 0x7f353535
    yabai -m config window_border_width 4
    yabai -m config window_border_radius 12
    yabai -m config window_border_blur on
    yabai -m config window_border_hidpi on
else
    echo "skipping unsupported yabai border settings for this build"
fi

echo "yabai configuration loaded.."
